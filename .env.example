# Copy to .env.local and fill in values. .env.local is gitignored.
# The gitleaks pre-commit hook will block commits that contain real
# secret values, so this file MUST stay with placeholder shapes only.

# ── LLM providers (required) ─────────────────────────────────
ANTHROPIC_API_KEY="<your-anthropic-key>"
OPENAI_API_KEY="<your-openai-key>"
GOOGLE_API_KEY="<your-google-ai-key>"

# ── ElevenLabs (required) ────────────────────────────────────
ELEVENLABS_API_KEY="<your-elevenlabs-key>"
VOICE_ID_ADVOCATE="<voice-id-for-advocate>"
VOICE_ID_CRITIC="<voice-id-for-critic>"
VOICE_ID_WILDCARD="<voice-id-for-wildcard>"

# ── Upstash KV (required for rate-limit + caches) ────────────
# Provision via `vercel link` + Vercel Marketplace, or set manually.
KV_REST_API_URL="https://<your-instance>.upstash.io"
KV_REST_API_TOKEN="<your-kv-token>"

# ── Optional model overrides (defaults baked into code) ──────
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# OPENAI_MODEL="gpt-4o"
# GOOGLE_MODEL="gemini-3.1-pro-preview"
# ELEVENLABS_TTS_MODEL="eleven_flash_v2_5"
# ELEVENLABS_OUTPUT_FORMAT="mp3_44100_128"

# ── Optional sampling caps ───────────────────────────────────
# FAST_MAX_TOKENS=100
# DEEP_MAX_TOKENS=800

# ── Optional rate-limit + budget knobs ───────────────────────
# RATE_LIMIT_IP_DAILY=30
# RATE_LIMIT_GLOBAL_DAILY=300
# DEBATE_COOLDOWN_MS=60000
# TTS_CHARS_IP_DAILY=20000
# TTS_CHARS_GLOBAL_DAILY=200000
# TTS_MAX_CHARS_PER_REQUEST=1000
# TTS_CACHE_TTL_SECONDS=2592000
# CACHE_TTL_SECONDS=2592000
